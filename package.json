{
  "name": "foodie-me-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b",
    "lint": "oxlint .",
    "preview": "vite preview",
    "build:pages": "npm run build && node scripts/prepare-pages-build.mjs",
    "test:e2e": "playwright test",
    "test:e2e:desktop": "playwright test --project=desktop-chrome",
    "test:e2e:mobile": "playwright test --project=mobile-chrome",
    "test:e2e:tablet": "playwright test --project=tablet-webkit",
    "test:e2e:chromium": "playwright test --project=desktop-chrome --project=mobile-chrome",
    "deploy:check": "npm run typecheck && npm run build:pages && npm run test:e2e:mobile",
    "ci:local": "npm run verify",
    "verify": "npm run lint && npm run typecheck && npm run build:pages && npm run test:e2e"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "oxlint": "^1.69.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.0"
  }
}
